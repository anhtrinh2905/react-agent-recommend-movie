# OPENAI SETTINGS
OPENAI_API_KEY=your-openai-api-key

# DEEPSEEK SETTINGS
# Get API key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key

# GEMINI SETTINGS
# Get API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# TMDB (The Movie Database) — free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key
TMDB_LANGUAGE=vi-VN
TMDB_REGION=VN

# OLLAMA SETTINGS (requires Ollama server: https://ollama.com)
# Run: ollama serve && ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# LAB CONFIG
# Options: gpt-4o-mini | gpt-4o | deepseek-chat | deepseek-reasoner | gemini-2.5-flash-lite | qwen2.5:3b
DEFAULT_MODEL=gpt-4o-mini
LOG_LEVEL=INFO
