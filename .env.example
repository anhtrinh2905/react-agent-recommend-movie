# OPENAI SETTINGS
OPENAI_API_KEY=your_openai_api_key_here

# DEEPSEEK SETTINGS
# Get API key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# TMDB (The Movie Database) — free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_LANGUAGE=vi-VN
TMDB_REGION=VN

# OLLAMA SETTINGS (requires Ollama server: https://ollama.com)
# Run: ollama serve && ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# LAB CONFIG
# Options: gpt-4o | gpt-4o-mini | deepseek-chat | deepseek-reasoner | llama3.2:3b
DEFAULT_MODEL=gpt-4o
LOG_LEVEL=INFO
